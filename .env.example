# ─────────────────────────────────────────────────────────────────
# Smart Timetable System – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env (with real secrets) to GitHub.
# ─────────────────────────────────────────────────────────────────

# ── Core Flask ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false
PORT=5000

# ── Database ──────────────────────────────────────────────────────
# Local SQLite (default when DATABASE_URL is not set):
#   Leave this line commented out and SQLite will be used automatically.
# Render PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host/dbname

# ── File Uploads ──────────────────────────────────────────────────
UPLOAD_FOLDER=instance/uploads

# ── Seeding ───────────────────────────────────────────────────────
SEED_DEMO_DATA=true

# ── Password Reset – Base URL ─────────────────────────────────────
# Used to build the reset link sent to the user.
# Local development: leave as http://localhost:5000
# Render deployment: set to https://your-app-name.onrender.com
BASE_URL=http://localhost:5000

# ── Password Reset – SMTP / Email ────────────────────────────────
# These settings are required for real email delivery.
# If left blank, the reset link is printed to the console (dev mode).
#
# Gmail example (use an App Password, NOT your Google account password):
#   https://myaccount.google.com/apppasswords
#
# Render deployment note:
#   Set ALL variables below in the Render dashboard → Environment section.
#   MAIL_PASSWORD must be an App Password or SMTP-specific password.
#   Do NOT hardcode credentials or commit them to GitHub.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
